# BantuVoice FastAPI server config (loaded by `bantuvoice-serve`)
# Copy to `.env` and fill in real values.

# Shared secret. Must match `BANTUVOICE_API_KEY` in bantu-nextjs/.env
BANTUVOICE_API_KEY=change-me

# S3 / MinIO — must match the bucket the Next.js app writes voices to
# (BANTUVOICE_API_URL points the Next.js client at this server; voice_key is an S3 object key)
S3_ENDPOINT=http://10.10.10.45:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=chatterbox
S3_REGION=emea-west-1

# Optional: HuggingFace token if pulling private model weights
HF_ACCESS_TOKEN=

# Optional: HF mirror if huggingface.co is blocked from this host
# HF_ENDPOINT=https://hf-mirror.com
